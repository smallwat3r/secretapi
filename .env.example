# Copy this file to .env and fill in the values before running docker-compose.

# Required: password for the Redis instance.
# Generate a strong random value, e.g.: openssl rand -hex 32
REDIS_PASSWORD=change-me

# Optional: canonical hostname used for HTTPS redirects (prevents open redirect
# via a spoofed Host header). Set to the public hostname of your deployment.
# Example: CANONICAL_HOST=secretapi.example.com
CANONICAL_HOST=

# Optional: CIDR range of your trusted reverse proxy. When set, X-Real-IP and
# X-Forwarded-For headers are only trusted when the direct connection comes from
# within this range. Leave empty to always use RemoteAddr for rate limiting.
# Example: TRUSTED_PROXY_CIDR=10.0.0.0/8
TRUSTED_PROXY_CIDR=
